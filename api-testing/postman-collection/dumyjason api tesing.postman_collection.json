      "item": [
        {
          "name": "TC Auth 01 valid login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {\r",
                  "    pm.response.to.have.status(200);\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Token generated\", function () {\r",
                  "    var data = pm.response.json();\r",
                  "    pm.expect(data.accessToken).to.exist;\r",
                  "});\r",
                  "\r",
                  "pm.test(\"Username verified\", function () {\r",
                  "    var data = pm.response.json();\r",
                  "    pm.expect(data.username).to.exist;\r",
                  "});\r",
                  "\r",
                  "var data = pm.response.json();\r",
                  "pm.environment.set(\"token\", data.accessToken);"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "raw",
              "raw": "{\r\n  \"username\": \"emilys\",\r\n  \"password\": \"emilyspass\"\r\n}",
